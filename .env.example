# --------------------------------------------------
# Lambda Monorepo Environment Template
# --------------------------------------------------
# Copy this file to .env for local development.
# Fill only the values needed for the functions you are running.


# --------------------------------------------------
# Core Shared Settings
# --------------------------------------------------
MONGODB_URI=
NEW_MONGODB_URI=
BUSINESS_MONGODB_URI=
MONGODB_SECONDARY_DB_NAME=petpetclub_uat
ENABLE_DUAL_WRITE=false

JWT_SECRET=
JWT_BYPASS=false
ALLOWED_ORIGINS=http://localhost:3000,http://127.0.0.1:3000


# --------------------------------------------------
# AWS / S3 / Textract
# --------------------------------------------------
AWS_BUCKET_REGION=
AWS_BUCKET_NAME=
AWS_BUCKET_BASE_URL=
AWSACCESSID=
AWSSECRETKEY=

# Legacy aliases referenced by debug logging in some files
AWS_ACCESS_ID=
AWS_SECRET_KEY=


# --------------------------------------------------
# AI / ML / Vision Services
# --------------------------------------------------
GEMINI_API_KEY=
GEMINI_KEY_1=
GEMINI_KEY_2=
GEMINI_KEY_3=

VM_PUBLIC_IP=
DOCKER_IMAGE=
HEATMAP=
VM_BREED_PUBLIC_IP=
BREED_DOCKER_IMAGE=
FACEID_API=


# --------------------------------------------------
# Email / SMTP
# --------------------------------------------------
SMTP_HOST=
SMTP_PORT=465
SMTP_USER=
SMTP_PASS=
SMTP_FROM=


# --------------------------------------------------
# WhatsApp / Messaging
# --------------------------------------------------
WHATSAPP_BEARER_TOKEN=

# Recommended for future cleanup of hardcoded Twilio credentials
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_VERIFY_SERVICE_SID=


# --------------------------------------------------
# Logistics / Shipping / Short Links
# --------------------------------------------------
SF_CUSTOMER_CODE=
SF_SANDBOX_CHECK_CODE=
SF_PRODUCTION_CHECK_CODE=
CUTTLY_API_KEY=


# --------------------------------------------------
# API Proxy / Upstream Routing
# --------------------------------------------------
AWS_API_KEY=
AWS_API_BASE_DEV=
AWS_API_BASE_PROD=


# --------------------------------------------------
# Networking / Ops
# --------------------------------------------------
ELASTIC_IPS=


# --------------------------------------------------
# Local Website App
# --------------------------------------------------
PORT=4000
