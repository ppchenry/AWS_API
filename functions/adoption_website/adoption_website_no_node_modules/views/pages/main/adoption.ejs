<head>
    <link href="https://fonts.googleapis.com/css2?family=Poppins:wght@400;500;600&display=swap" rel="stylesheet">
    <script>
        const lang = "<%=lang%>";
        let url = new URL(window.location.href);
        let search_params = url.searchParams;
        const page = search_params.get("page");
        if (page == null || page == undefined || page == "") {
            search_params.set("page", "1");
            url.search = search_params.toString();
            window.history.pushState("", "", url.toString());
            window.location.href = url;
        }
        const locationParam = search_params.getAll("location");
        const animalTypeParam = search_params.getAll("animal_type");
        const sexParam = search_params.getAll("sex");
        const ageParam = search_params.getAll("age");
        let pagination = [];
        let currentPage = Number(page);
        let maxPage = 0;

        function showFilterButton() {
            const filterSidebar = document.querySelector(".filter-sidebar");
            const opaqueBg = document.querySelector(".emptySidebar");
            filterSidebar.classList.add("filter-sidebar-hp");
            filterSidebar.classList.remove("filter-sidebar");
            opaqueBg.style.display = "block";
        }

        function closeFilterButton() {
            const filterSidebar = document.querySelector(".filter-sidebar-hp");
            const opaqueBg = document.querySelector(".emptySidebar");
            filterSidebar.classList.remove("filter-sidebar-hp");
            filterSidebar.classList.add("filter-sidebar");
            opaqueBg.style.display = "none";
        }

        function showList(id) {
            const filterItem = document.getElementById(id);
            const image = document.getElementById(`${id}List`);
            if (filterItem.classList.contains("hide")) {
                filterItem.classList.add("d-flex");
                filterItem.classList.remove("hide");
                image.setAttribute("src", "https://petpetclub.s3.ap-southeast-1.amazonaws.com/static-content/68230d66e3965735838be261.png");
            } else {
                filterItem.classList.remove("d-flex");
                filterItem.classList.add("hide");
                image.setAttribute("src", "https://petpetclub.s3.ap-southeast-1.amazonaws.com/static-content/682411fae3965735838c5760.png");

            }
        }

        function imgError(image) {
            image.onerror = "";
            image.src = "https://petpetclub.s3.ap-southeast-1.amazonaws.com/static-content/67bd6f89d80c435bfa35d35e.jpg";
            return true;
        }

        async function fetchAdoptionList(params) {
            await fetch(`https://api.phealth.com.hk/api/adoption${params}`, {
                method: "GET",
                headers: {
                    "Content-Type": "application/json",
                },
            })
                // await fetch(`http://localhost:8984/api/adoption${params}`, {
                //     method: "GET",
                //     headers: {
                //     "Content-Type": "application/json",
                //     },
                // })
                .then((response) => response.json())
                .then((data) => {
                    console.log("DATA FETCHED: ", data);
                    const dataElement = document.querySelector('#petList');
                    dataElement.replaceChildren();
                    if (data.adoptionList.length != 0) {
                        data.adoptionList.forEach((item, index) => {
                            let gender;
                            let breed;
                            let age;
                            let name;
                            if (item.Breed == "unknown" || item.Breed == "Unknown" || item.Breed == undefined) {
                                breed = "N/A";
                            } else {
                                breed = item.Breed;
                            }

                            if (item.Sex == undefined || item.Sex == "unknown" || item.Sex == "Unknown") {
                                gender = "<% if (lang == 'zh') { %>未知<% } else { %>Unknown<% } %>";
                            } else if (item.Sex == "F") {
                                if (lang == "zh") {
                                    gender = "雌性";
                                } else {
                                    gender = "Female";
                                }
                            } else if (item.Sex == "M") {
                                if (lang == "zh") {
                                    gender = "雄性"
                                } else {
                                    gender = "Male"
                                }
                            }

                            if (item.Name == undefined || item.Name == "unknown" || item.Name == "Unknown") {
                                name = "<% if (lang == 'zh') { %>未知<% } else { %>Unknown<% } %>";
                            } else {
                                name = item.Name
                            }

                            if (item.Age == undefined || item.Age == "unknown" || item.Age == "Unknown") {
                                age = "&nbsp;";
                            } else if (item.Age >= 12) {
                                const year = item.Age / 12;
                                const month = item.Age - (year * 12);
                                if (month == 0) {
                                    if (lang == "zh") {
                                        age = year + "歲";
                                    } else {
                                        age = year + "Year(s)";
                                    }
                                } else {
                                    if (lang == "zh") {
                                        age = year + "歲" + month + "個月";
                                    } else {
                                        age = year + "Year(s)" + month + "Month(s)";
                                    }
                                }

                            } else {
                                if (lang == "zh") {
                                    age = item.Age + "個月";
                                } else {
                                    age = item.Age + "Month(s)";
                                }
                            }

                            if (Array.isArray(item.Image_URL)) {
                                image = item.Image_URL[0];
                            } else {
                                image = item.Image_URL;
                            }

                            dataElement.insertAdjacentHTML('afterbegin', `
                            <div class="col-md-3 col-6 pet-card">
                                <img src="${image}" onerror="imgError(this)">
                                <div class="pet-info">
                                    <div class="pet-name-breed">
                                        <div style="font-weight: bold; font-size: 14px">${name}</div>
                                        <div class = "pet-details">
                                            <div>${gender}</div>
                                            <div  style="border-right: 1px solid #C5C1C1; height: 15px"></div>
                                            <div>${age}</div>
                                            <div  style="border-right: 1px solid #C5C1C1; height: 15px"></div>
                                            <div>${breed}</div>
                                        </div>
                                    </div>
                                </div>
                            </div>
                        `);
                            let clickableCard = document.querySelectorAll(".pet-card");
                            clickableCard[0].addEventListener("click", function () {
                                const url = window.location.href;
                                const urlObj = new URL(url);
                                const newUrl = urlObj.origin + "/" + item._id;
                                window.location.href = newUrl;
                            });
                        });
                    } else {
                        dataElement.insertAdjacentHTML('afterbegin', `
                        <div class="d-flex justify-content-center flex-column align-items-center" style="height: 100%; width: 100%;">
                            <img src="https://petpetclub.s3.ap-southeast-1.amazonaws.com/static-content/67b5b0a9015466946c7ef5b9.png" width="100px" height="100px">
                            <div><% if (lang == "zh") { %>未找到總數<% } else { %>Results are not found<% } %></div>
                        </div>
                    `)
                    }
                    maxPage = data.maxPage;
                    if (currentPage != 1) {
                        if (data.adoptionList.length != 16) {
                            document.querySelector(".totalResults").innerHTML = `<% if (lang == 'zh') { %>顯示 ${(1 + 16 * (currentPage - 1))}-${(16 * (currentPage - 1)) + data.adoptionList.length} 的 ${data.totalResult} 隻寵物<% } else { %>Showing ${(1 + 16 * (currentPage - 1))}-${(16 * (currentPage - 1)) + data.adoptionList.length} of ${data.totalResult} pets<% } %> `
                        } else {
                            document.querySelector(".totalResults").innerHTML = `<% if (lang == 'zh') { %>顯示 ${(1 + 16 * (currentPage - 1))}-${16 * (currentPage)} 的 ${data.totalResult} 隻寵物<% } else { %>Showing ${(1 + 16 * (currentPage - 1))}-${16 * (currentPage)} of ${data.totalResult} pets<% } %> `
                        }
                    } else {
                        if (data.adoptionList.length != 16) {
                            document.querySelector(".totalResults").innerHTML = `<% if (lang == 'zh') { %>顯示 1-${data.adoptionList.length} 的 ${data.totalResult} 隻寵物<% } else { %>Showing 1-${data.adoptionList.length} of ${data.totalResult} pets<% } %> `
                        } else {
                            document.querySelector(".totalResults").innerHTML = `<% if (lang == 'zh') { %>顯示 1-16 的 ${data.totalResult} 隻寵物<% } else { %>Showing 1-16 of ${data.totalResult} pets<% } %> `
                        }
                    }
                })
                .catch((error) => {
                    console.error("Error in POST request:", error);
                });
        }

