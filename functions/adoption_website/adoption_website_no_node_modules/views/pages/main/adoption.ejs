                            ${htmlArray.join("")}
                        </select>
                        <div style="color: #E6E6E6; font-size: 12px"><% if (lang == 'zh') { %>/${maxPage}頁<% } else { %>/ Page ${maxPage}<% } %> </div>
                        <div class="${currentPage == maxPage ? 'hide' : ''}" onclick="generatePagination(${Number(currentPage) + 1})" style="width=31px;height=31px;border=1px solid #E6E6E6;border-radius:2px">
