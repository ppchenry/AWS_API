        async function testFunction(index) {
            var x = document.getElementById("page0").value;;
            var y = document.getElementById("page1").value;
            if (index == 0) {
                y = x;
            } else if (index == 1) {
                x = y;
            }
            currentPage = x;
            console.log(currentPage);
            let url = new URL(window.location.href);
            let search_params = url.searchParams;
            search_params.set("page", `${currentPage}`);
            url.search = search_params.toString();
            window.history.pushState("", "", url.toString());
            const paginationHTML = document.querySelectorAll('#pagination');
            paginationHTML.forEach((item, index) => {
                item.replaceChildren();
                if (maxPage != 0) {
                    let htmlArray = [];
                    for (var i = 0; i < maxPage; i++) {
                        if (currentPage == i + 1) {
                            htmlArray.push(`<option value=${i + 1} selected>${i + 1}</option>`)
                        } else {
                            htmlArray.push(`<option value=${i + 1}>${i + 1}</option>`)
                        }
                    }
                    item.insertAdjacentHTML("afterbegin", `
                        <div class="${currentPage == 1 ? 'hide' : ''}" onclick="generatePagination(${currentPage - 1})" style="width=31px;height=31px;border=1px solid #E6E6E6;border-radius:2px">
                            <img src="https://petpetclub.s3.ap-southeast-1.amazonaws.com/static-content/Frame+7.png" width="31px" height="31px">   
                        </div>
                        <select name="page" id="page${index}" onchange="testFunction(${index})" style="height:31px;border:1px solid #E6E6E6;border-radius:2px">
                            ${htmlArray.join("")}
                        </select>
                        <div style="color: #E6E6E6; font-size: 12px"><% if (lang == 'zh') { %>/${maxPage}頁<% } else { %>/ Page ${maxPage}<% } %> </div>
                        <div class="${currentPage == maxPage ? 'hide' : ''}" onclick="generatePagination(${Number(currentPage) + 1})" style="width=31px;height=31px;border=1px solid #E6E6E6;border-radius:2px">
                            <img src="https://petpetclub.s3.ap-southeast-1.amazonaws.com/static-content/Frame+6+(1).png" width="31px" height="31px">    
                        </div>
                    `);
                }
            });
            await fetchAdoptionList(url.search);
        }


        async function generatePagination(pageNo) {
            currentPage = pageNo
            var x = document.getElementById("page0").value;;
            var y = document.getElementById("page1").value;
            x = currentPage;
            y = currentPage
            console.log(currentPage);
            let url = new URL(window.location.href);
            let search_params = url.searchParams;
            search_params.set("page", `${currentPage}`);
            url.search = search_params.toString();
            window.history.pushState("", "", url.toString());
            const paginationHTML = document.querySelectorAll('#pagination');
            paginationHTML.forEach((item, index) => {
                item.replaceChildren();
                if (maxPage != 0) {
                    let htmlArray = [];
                    for (var i = 0; i < maxPage; i++) {
                        if (currentPage == i + 1) {
                            htmlArray.push(`<option value=${i + 1} selected>${i + 1}</option>`)
                        } else {
                            htmlArray.push(`<option value=${i + 1}>${i + 1}</option>`)
                        }
                    }
                    item.insertAdjacentHTML("afterbegin", `
                        <div class="${currentPage == 1 ? 'hide' : ''}" onclick="generatePagination(${currentPage - 1})" style="width=31px;height=31px;border=1px solid #E6E6E6;border-radius:2px">
                            <img src="https://petpetclub.s3.ap-southeast-1.amazonaws.com/static-content/Frame+7.png" width="31px" height="31px">   
                        </div>
                        <select name="page" id="page${index}" onchange="testFunction(${index})" style="height:31px;border:1px solid #E6E6E6;border-radius:2px">
                            ${htmlArray.join("")}
                        </select>
                        <div style="color: #E6E6E6; font-size: 12px"><% if (lang == 'zh') { %>/${maxPage}頁<% } else { %>/ Page ${maxPage}<% } %> </div>
                        <div class="${currentPage == maxPage ? 'hide' : ''}" onclick="generatePagination(${Number(currentPage) + 1})" style="width=31px;height=31px;border=1px solid #E6E6E6;border-radius:2px">
                            <img src="https://petpetclub.s3.ap-southeast-1.amazonaws.com/static-content/Frame+6+(1).png" width="31px" height="31px">    
                        </div>
                    `);
                }
            });
            await fetchAdoptionList(url.search);
        }

        function addFunction(params) {
            const selectedFiltersContainer = document.querySelector(".selected-filters .tags");
            const clearAllButton = document.querySelector(".clear-all-btn");
            const filterItems = document.querySelectorAll(`#${params} li`);
            filterItems.forEach((item) => {
                item.addEventListener("click", async function (index) {
                    if (this.classList.contains("selected")) {
                        return; // Do nothing if already selected
                    }
                    let url = new URL(window.location.href);
                    let search_params = url.searchParams;
                    search_params.append(params, this.getAttribute("data-value"));
                    search_params.set("page", 1);
                    currentPage = 1;
                    url.search = search_params.toString();
                    window.history.pushState("", "", url.toString());
                    // Check if the item is already selected
                    pagination = [];
                    // Add to selected filters
                    this.classList.add("selected");
                    const tag = document.createElement("span");
                    tag.classList.add("tag");
                    tag.textContent = this.textContent;

                    // Add "remove" icon to the tag
                    const removeIcon = document.createElement("span");
                    removeIcon.classList.add("remove-icon");
                    removeIcon.textContent = "×";
                    tag.appendChild(removeIcon);

                    // Add the tag to the selected filters container
                    selectedFiltersContainer.appendChild(tag);

                    // Handle tag removal
                    removeIcon.addEventListener("click", async function () {
                        const paramValue = item.getAttribute("data-value");
                        let deleteUrl = new URL(window.location.href);
                        let delete_search_params = deleteUrl.searchParams;
                        delete_search_params.delete(params, item.getAttribute("data-value"));
                        delete_search_params.set("page", "1");
                        currentPage = 1;
                        deleteUrl.search = delete_search_params.toString();
                        window.history.pushState("", "", deleteUrl.toString());
                        pagination = [];
                        await fetchAdoptionList(deleteUrl.search);
                        const paginationHTML = document.querySelectorAll('#pagination');
                        paginationHTML.forEach((item, index) => {
                            item.replaceChildren();
                            if (maxPage != 0) {
                                let htmlArray = [];
                                for (var i = 0; i < maxPage; i++) {
                                    if (currentPage == i + 1) {
                                        htmlArray.push(`<option value=${i + 1} selected>${i + 1}</option>`)
                                    } else {
                                        htmlArray.push(`<option value=${i + 1}>${i + 1}</option>`)
                                    }
                                }
                                item.insertAdjacentHTML("afterbegin", `
                                    <div class="${currentPage == 1 ? 'hide' : ''}" onclick="generatePagination(${currentPage - 1})" style="width=31px;height=31px;border=1px solid #E6E6E6;border-radius:2px">
                                        <img src="https://petpetclub.s3.ap-southeast-1.amazonaws.com/static-content/Frame+7.png" width="31px" height="31px">   
                                    </div>
                                    <select name="page" id="page${index}" onchange="testFunction(${index})" style="height:31px;border:1px solid #E6E6E6;border-radius:2px">
                                        ${htmlArray.join("")}
                                    </select>
                                    <div style="color: #E6E6E6; font-size: 12px"><% if (lang == 'zh') { %>/${maxPage}頁<% } else { %>/ Page ${maxPage}<% } %> </div>
                                    <div class="${currentPage == maxPage ? 'hide' : ''}" onclick="generatePagination(${Number(currentPage) + 1})" style="width=31px;height=31px;border=1px solid #E6E6E6;border-radius:2px">
                                        <img src="https://petpetclub.s3.ap-southeast-1.amazonaws.com/static-content/Frame+6+(1).png" width="31px" height="31px">    
                                    </div>
                                `);
                            }
                        });
                        selectedFiltersContainer.removeChild(tag);
                        item.classList.remove("selected");
                    });
                    await fetchAdoptionList(url.search);
                    const paginationHTML = document.querySelectorAll('#pagination');
                    paginationHTML.forEach((item, index) => {
                        item.replaceChildren();
                        if (maxPage != 0) {
                            let htmlArray = [];
                            for (var i = 0; i < maxPage; i++) {
                                if (currentPage == i + 1) {
                                    htmlArray.push(`<option value=${i + 1} selected>${i + 1}</option>`)
                                } else {
                                    htmlArray.push(`<option value=${i + 1}>${i + 1}</option>`)
                                }
                            }
                            item.insertAdjacentHTML("afterbegin", `
                                <div class="${currentPage == 1 ? 'hide' : ''}" onclick="generatePagination(${currentPage - 1})" style="width=31px;height=31px;border=1px solid #E6E6E6;border-radius:2px">
                                    <img src="https://petpetclub.s3.ap-southeast-1.amazonaws.com/static-content/Frame+7.png" width="31px" height="31px">   
                                </div>
                                <select name="page" id="page${index}" onchange="testFunction(${index})" style="height:31px;border:1px solid #E6E6E6;border-radius:2px">
                                    ${htmlArray.join("")}
                                </select>
                                <div style="color: #E6E6E6; font-size: 12px"><% if (lang == 'zh') { %>/${maxPage}頁<% } else { %>/ Page ${maxPage}<% } %> </div>
                                <div class="${currentPage == maxPage ? 'hide' : ''}" onclick="generatePagination(${Number(currentPage) + 1})" style="width=31px;height=31px;border=1px solid #E6E6E6;border-radius:2px">
                                    <img src="https://petpetclub.s3.ap-southeast-1.amazonaws.com/static-content/Frame+6+(1).png" width="31px" height="31px">    
                                </div>
                            `);
                        }
                    });
                });
            });

            clearAllButton.addEventListener("click", async function () {
                // Remove all tags
                selectedFiltersContainer.innerHTML = "";
                let deleteUrl = new URL(window.location.href);
                let delete_search_params = deleteUrl.searchParams;
                if (delete_search_params.has("animal_type")) {
                    delete_search_params.delete("animal_type");
                }
                if (delete_search_params.has("sex")) {
                    delete_search_params.delete("sex");
                }
                if (delete_search_params.has("location")) {
                    delete_search_params.delete("location");
                }
                if (delete_search_params.has("age")) {
                    delete_search_params.delete("age");
                }

                if (delete_search_params.has("search")) {
                    delete_search_params.delete("search");
                }

                delete_search_params.set("page", "1");
                currentPage = 1;
                deleteUrl.search = delete_search_params.toString();
                window.history.pushState("", "", deleteUrl.toString());
                pagination = [];
                console.log("CLEAR ALL BUTTON CLICKED");
                await fetchAdoptionList(deleteUrl.search);
                const paginationHTML = document.querySelectorAll('#pagination');
                paginationHTML.forEach((item, index) => {
                    item.replaceChildren();
                    if (maxPage != 0) {
                        let htmlArray = [];
                        for (var i = 0; i < maxPage; i++) {
                            if (currentPage == i + 1) {
                                htmlArray.push(`<option value=${i + 1} selected>${i + 1}</option>`)
                            } else {
                                htmlArray.push(`<option value=${i + 1}>${i + 1}</option>`)
                            }
                        }
                        item.insertAdjacentHTML("afterbegin", `
                            <div class="${currentPage == 1 ? 'hide' : ''}" onclick="generatePagination(${currentPage - 1})" style="width=31px;height=31px;border=1px solid #E6E6E6;border-radius:2px">
                                <img src="https://petpetclub.s3.ap-southeast-1.amazonaws.com/static-content/Frame+7.png" width="31px" height="31px">   
                            </div>
                            <select name="page" id="page${index}" onchange="testFunction(${index})" style="height:31px;border:1px solid #E6E6E6;border-radius:2px">
                                ${htmlArray.join("")}
                            </select>
                            <div style="color: #E6E6E6; font-size: 12px"><% if (lang == 'zh') { %>/${maxPage}頁<% } else { %>/ Page ${maxPage}<% } %> </div>
                            <div class="${currentPage == maxPage ? 'hide' : ''}" onclick="generatePagination(${Number(currentPage) + 1})" style="width=31px;height=31px;border=1px solid #E6E6E6;border-radius:2px">
                                <img src="https://petpetclub.s3.ap-southeast-1.amazonaws.com/static-content/Frame+6+(1).png" width="31px" height="31px">    
                            </div>
                        `);
                    }
                });
                // Remove "selected" class from all filter items
                filterItems.forEach((item) => {
                    item.classList.remove("selected");
                });
            });


        }
        //filter group selection interaction
        document.addEventListener("DOMContentLoaded", function () {
            // Handle filter group item clicks
            addFunction("animal_type");
            addFunction("location");
            addFunction("sex");
            addFunction("age");
            document.getElementById("keywords").addEventListener("keyup", function (event) {
                if (event.keyCode === 13) {
                    // Check if Enter key is pressed
                    document.getElementById("search_keyword").click();
                    // Trigger button click
                }
            });
        });

        function toggleHeart(element) {
            element.classList.toggle("filled");
            element.textContent = element.classList.contains("filled") ? "❤️" : "♡";
        }


    </script>
