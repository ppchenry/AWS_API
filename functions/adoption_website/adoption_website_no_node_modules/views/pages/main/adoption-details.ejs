<!DOCTYPE html>
<html>

<head>
	<link href="https://fonts.googleapis.com/css2?family=Poppins:wght@400;500;600&display=swap" rel="stylesheet">
	<meta charset="UTF-8">
	<meta name="viewport" content="width=device-width, initial-scale=1.0">
	<meta property="og:url" content="" />
	<meta property="og:image" content="" />
	<meta property="og:type" content="" />
	<meta property="og:title" content="" />
	<meta property="og:description" content="" />
	<title>Pet Adoption - Hyena</title>
	<link href="https://cdn.jsdelivr.net/npm/bootstrap@5.1.3/dist/css/bootstrap.min.css" rel="stylesheet">
	<script src="https://cdn.jsdelivr.net/npm/bootstrap@5.1.3/dist/js/bootstrap.bundle.min.js"></script>
	<script>
		var url = window.location.href;
		var id = url.substring(url.lastIndexOf('/') + 1);
		let path = url;
		let split = path.split("/");
		let splicedStr = split.slice(0, split.length - 1).join("/") + "/";
		console.log("splicedStr: ", splicedStr);
		const lang = "<%=lang%>";
		document.addEventListener("DOMContentLoaded", async function () {
			await fetch(`https://api.phealth.com.hk/api/adoption/${id}`, {
				method: "GET",
				headers: {
					"Content-Type": "application/json",
				},
			})
				.then((response) => response.json())
				.then((data) => {
					console.log("DATA: ", data.pet);
					const metaImage = document.querySelector('meta[property="og:image"]');
					metaImage.setAttribute("content", data.pet.Image_URL);
					const metaTitle = document.querySelector('meta[property="og:title"]');
					metaTitle.setAttribute("content", "Pet Pet Club");
					const metaUrl = document.querySelector('meta[property="og:url"]');
					metaUrl.setAttribute("content", window.location.href);
					const params = document.querySelectorAll(".value");
					const namePlaceholder = document.querySelectorAll(".name");
					const remark = document.querySelector(".remarks");
					const button = document.querySelector(".adoption-button");
					const image = document.querySelector(".image-container");
					const fbButton = document.querySelectorAll(".fb-share-button");
					// anchor[0].setAttribute("href", `https://www.facebook.com/sharer/sharer.php?u=${window.location.href}`);
					fbButton.forEach((item) => {
						console.log("item", item);
						item.setAttribute("data-href", window.location.href);
					});
					// Remove unused array variable and commented code
					console.log(data.pet.Image_URL.length);
					if (data.pet.Image_URL.length != 1) {
						// Generate carousel items for multiple images
						let carouselItems = '';
						let carouselIndicators = '';
						
						data.pet.Image_URL.forEach((imgUrl, index) => {
							const isActive = index === 0 ? 'active' : '';
							carouselItems += `
								<div class="carousel-item ${isActive} image-placeholder">
									<img src="${imgUrl}" onerror="imgError(this)" class="d-block w-100" alt="..." id="index${index}">
								</div>
							`;
							
							const indicatorActive = index === 0 ? 'active' : '';
							carouselIndicators += `
								<div type="button" data-bs-target="#carouselExampleIndicators" data-bs-slide-to="${index}" class="${indicatorActive} imageIndicatorTest" aria-current="${index === 0 ? 'true' : 'false'}" aria-label="Slide ${index + 1}"></div>
							`;
						});
						
						image.insertAdjacentHTML("afterbegin", `
								<div id="carouselExampleIndicators" class="carousel slide">
									<div class="carousel-inner">
										${carouselItems}
									</div>
									<button class="carousel-control-prev" type="button" data-bs-target="#carouselExampleIndicators" data-bs-slide="prev" style="background-color: transparent; border: none;">
										<span class="carousel-control-prev-icon" aria-hidden="true"></span>
									</button>
									<button class="carousel-control-next" type="button" data-bs-target="#carouselExampleIndicators" data-bs-slide="next" style="background-color: transparent; border: none;">
										<span class="carousel-control-next-icon" aria-hidden="true"></span>
									</button>
									<div class="carousel-indicators" style="position: relative; bottom: 0px; margin-top: 10px;">
										${carouselIndicators}
									</div>
								</div>
						`);
						
					} else {
						image.insertAdjacentHTML("afterbegin", `
								<div id="carouselExampleIndicators" class="carousel slide">
									<div class="carousel-inner">
										<div class="carousel-item active image-placeholder">
											<img src="${data.pet.Image_URL[0]}" onerror="imgError(this)" class="d-block w-100" alt="..." id="index0">
										</div>
									</div>
									<div class="carousel-indicators" style="position: relative; bottom: 0px; margin-top: 10px;">
										<div type="button" data-bs-target="#carouselExampleIndicators" data-bs-slide-to="0" class="active imageIndicatorTest" aria-current="true" aria-label="Slide 1"></div>
									</div>
								</div>
						`);

						carouselInner = document.getElementsByClassName("carousel-inner");
						console.log(carouselInner[0]);
					}
					
					// image.insertAdjacentHTML("afterbegin", `
					//     <img src="${data.pet.Image_URL}" onerror="imgError(this)" class="petPicture" >
					// `);


					if (data.pet.Remark == undefined) {
						remark.innerHTML = "<% if (lang == 'zh') { %>沒有相關資料<% } else { %>No related information<% } %>"
					} else if (data.pet.Remark == "unknown" || data.pet.Remark == "") {
						remark.innerHTML = "<% if (lang == 'zh') { %>未知<% } else { %>Unknown<% } %>"
					} else {
						remark.innerHTML = data.pet.Remark;
					}



					if (data.pet.Name == undefined) {
						namePlaceholder.forEach((item) => {
							item.innerHTML = "<% if (lang == 'zh') { %>沒有相關資料<% } else { %>No related information<% } %>";
						});
					} else if (data.pet.Name == "unknown" || data.pet.Name == "") {
						namePlaceholder.forEach((item) => {
							item.innerHTML = "<% if (lang == 'zh') { %>未知<% } else { %>Unknown<% } %>";
						});
					} else {
						namePlaceholder.forEach((item) => {
							item.innerHTML = ` ${data.pet.Name}`;
						});
					}
					if (data.pet.Age == undefined) {
						params[2].innerHTML = "<% if (lang == 'zh') { %>沒有相關資料<% } else { %>No related information<% } %>"
					} else if (data.pet.Age == "unknown") {
						params[1].innerHTML = "<% if (lang == 'zh') { %>未知<% } else { %>Unknown<% } %>"
					} else if (data.pet.Age >= 12) {
						const year = data.pet.Age / 12;
						const month = data.pet.Age - (year * 12);
						if (month == 0) {
							if (lang == "zh") {
								params[1].innerHTML = year + "歲";
							} else {
								params[1].innerHTML = year + "Year(s)";
							}
						} else {
							if (lang == "zh") {
								params[1].innerHTML = year + "歲" + month + "月";
							} else {
								params[1].innerHTML = year + "Year(s)" + month + "Month(s)";
							}
						}

					} else {
						if (lang == "zh") {
							params[1].innerHTML = data.pet.Age + "月";
						} else {
							params[1].innerHTML = data.pet.Age + "Month(s)";
						}
					}

					if (data.pet.Breed == undefined) {
						params[2].innerHTML = "<% if (lang == 'zh') { %>沒有相關資料<% } else { %>No related information<% } %>"
					} else if (data.pet.Breed == "unknown" || data.pet.breed == "") {
						params[2].innerHTML = "<% if (lang == 'zh') { %>未知<% } else { %>Unknown<% } %>"
					} else {
						params[2].innerHTML = data.pet.Breed;
					}

					if (data.pet.Sex == undefined) {
						params[0].innerHTML = "<% if (lang == 'zh') { %>沒有相關資料<% } else { %>No related information<% } %>"
					} else if (data.pet.Sex == "unknown" || data.pet.Sex == "") {
						params[0].innerHTML = "<% if (lang == 'zh') { %>未知<% } else { %>Unknown<% } %>"
					} else if (data.pet.Sex == "F") {
						params[0].innerHTML = "<% if (lang == 'zh') { %>雌性<% } else { %>Female<% } %>";
					} else {
						params[0].innerHTML = " <% if (lang == 'zh') { %>雄性<% } else { %>Male<% } %>";
					}

					if (data.pet.AdoptionSite == undefined) {
						params[3].innerHTML = "<% if (lang == 'zh') { %>沒有相關資料<% } else { %>No related information<% } %>"
					} else if (data.pet.AdoptionSite == "unknown" || data.pet.AdoptionSite == "") {
						params[3].innerHTML = "<% if (lang == 'zh') { %>未知<% } else { %>Unknown<% } %>"
					} else {
						params[3].innerHTML = data.pet.AdoptionSite;
					}

					button.addEventListener("click", async function () {
						await fetch(`https://api.phealth.com.hk/adoption/${id}`, {
							method: "POST",
							headers: {
								"Content-Type": "application/json",
							},
						});
						window.open(data.pet.URL, '_blank').focus();
					});
				})
				.catch((error) => {
					console.error("Error in POST request:", error);
				});
			let path = window.location.href;
			let split = path.split("/");
			let splicedStr = split.slice(0, split.length - 1).join("/") + "/";
			console.log(splicedStr);
			const anchor = document.getElementById("anchor");
			anchor.setAttribute("href", splicedStr)
		});
		function imgError(image) {
			image.onerror = "";
			image.src = "https://petpetclub.s3.ap-southeast-1.amazonaws.com/static-content/67bd6f89d80c435bfa35d35e.jpg";
			return true;
		}

		// Function to handle carousel navigation
		function handleCarouselNavigation(direction) {
			const carousel = document.getElementById('carouselExampleIndicators');
			if (carousel) {
				const bsCarousel = new bootstrap.Carousel(carousel);
				if (direction === 'next') {
					bsCarousel.next();
				} else if (direction === 'prev') {
					bsCarousel.prev();
				}
			}
		}

	</script>
	<style>
		.lower-section {
			padding-top: 40px;
			padding-bottom: 40px;
			width: 100%;
		}

		.upper-section {
			width: 100%;
		}

		.social-icons {
			display: flex;
			align-items: center;
			padding-top: 10px;
		}

		.social-iconsHP {
			display: none;
		}

		.image-placeholder {
			width: 100%;
			max-width: 320px;
			max-height: 320px;
			height: 100%;
			object-fit: contain;
		}

		.imageIndicatorTest {
			border-radius: 50%;
			width: 5px;
			height: 5px;
			background-color: #F4F6FA;
		}

		.imageIndicatorTest.active {
			background-color: #969696;
		}

		.adoption-button {
			background-color: #31BACE;
			color: white;
			border-radius: 20px;
			width: 250px;
			padding: 8px;
			display: flex;
			justify-content: center;
			align-items: center;
			margin-top: 10px;
		}

		.petAdvertisement {
			display: inline-block;
			position: relative;
			width: 100%;
		}

		.petAdvertisementHP {
			display: none;
			padding: 20px;
		}

		.petInformation {
			display: flex;
			width: 100%;
		}

		.petPictureSection {
			width: 40%;
		}

		.informationDetailTitle {
			margin-right: 10%;
			color: #248593;
			width: 30%
		}



		.informationDetailText {
			width: 100%;
			word-break: normal;
			overflow-wrap: normal;
		}

		.petPicture {
			width: 80%;
			height: auto;
			max-height: 324px;
			max-width: 324px;
		}

		.informationDetail {
			width: 100%;
			padding: 10px;
		}

		@media (max-width: 575px) {
			.petAdvertisement {
				display: none;
			}

			.petAdvertisementHP {
				display: block;
			}

			.upper-section {
				padding-left: 20px;
				padding-right: 20px;
				width: 100%;
			}

			.lower-section {
				width: 100%;
			}

			.petInformation {
				display: block;
			}

			.petPictureSection {
				width: 100%;
			}

			.petPicture {
				width: 100%;
				max-height: none;
				max-width: none;
			}

			.social-icons {
				display: none;
			}

			.social-iconsHP {
				display: flex;
				align-items: center;
				padding-top: 10px;
			}

			.informationDetailText {
				width: 150px;
				word-break: normal;
				overflow-wrap: break-word;
			}

		}

		* {
			font-family: Poppins;
		}
	</style>

</head>

<body>
	<div id="fb-root"></div>
	<script>(function (d, s, id) {
			var js, fjs = d.getElementsByTagName(s)[0];
			if (d.getElementById(id)) return;
			js = d.createElement(s); js.id = id;
			js.src = "https://connect.facebook.net/en_US/sdk.js#xfbml=1&version=v3.0";
			fjs.parentNode.insertBefore(js, fjs);
		}(document, 'script', 'facebook-jssdk'));</script>
	<!-- Upper Section -->
	<div class="d-flex justify-content-center flex-column align-items-center container"
		style="padding: 0px 8%; margin: 0; max-width: 100%;">
		<div class="upper-section">
			<div style="font-size: 16px; padding-top: 135px; padding-bottom: 20px;">
				<a style="color: #969696; cursor: pointer; text-decoration: none;"
					onmouseover="this.style.color='#02090A';" onmouseout="this.style.color='#969696';"
					href="https://uat1.petpetclub.com.hk/index.html">
					<% if (lang=='zh' ) { %>首頁<% } else { %>Home<% } %>
				</a> > <a href="" style="color: #969696; text-decoration: none;"
					onmouseover="this.style.color='#02090A';" onmouseout="this.style.color='#969696';" id="anchor">
					<% if (lang=='zh' ) { %>寵物領養<% } else { %>Pet Adoption<% } %>
				</a> > <span class="name"></span>
			</div>
			<div class="petInformation">
				<div class="petPictureSection">
					<div class="image-container">
					</div>
					<div class="greeting">
						<div class="social-icons">
							<img src="https://petpetclub.s3.ap-southeast-1.amazonaws.com/static-content/6822e5a8e3965735838bc5eb.png"
								width="17px" height="17px">
							<div style="margin-left: 5px; margin-right: 5px">
								<% if (lang=='zh' ) { %>分享：<% } else { %>Share:<% } %>
							</div>
							<img src="https://petpetclub.s3.ap-southeast-1.amazonaws.com/static-content/6822e611e3965735838bc81e.png"
								width="17px" height="17px">
							<!-- Facebook Icon
							<div class="fb-share-button" data-layout="" data-size="">
							<a target="_blank" class="fb-xfbml-parse-ignore">
								<svg width="60" height="60" viewBox="0 0 60 60" fill="none" xmlns="http://www.w3.org/2000/svg">
								<path d="M60 30C60 45.152 48.768 57.6782 34.1779 59.7115C32.8132 59.9015 31.4174 60 30.0009 60C28.365 60 26.7601 59.8687 25.1951 59.6165C10.9089 57.3172 0 44.9326 0 30C0 13.4314 13.431 0 29.9991 0C46.5672 0 59.9983 13.4314 59.9983 30H60Z" fill="#1877F7"/>
								<path d="M34.1778 24.0866V30.6218H42.2623L40.9823 39.427H34.1778V59.7114C32.8131 59.9015 31.4173 59.9999 30.0008 59.9999C28.3649 59.9999 26.7601 59.8686 25.195 59.6164V39.427H17.7393V30.6218H25.195V22.6269C25.195 17.6655 29.2165 13.6421 34.1795 13.6421V13.6473C34.1933 13.6473 34.2072 13.6421 34.221 13.6421H42.2641V21.2552H37.0091C35.4458 21.2552 34.1795 22.5215 34.1795 24.0849L34.1778 24.0866Z" fill="white"/>
								</svg>
							</a>
							</div> -->
						</div>
					</div>
				</div>
				<div class="informationDetail">
					<div class="name" style="font-size: 24px; font-weight: bold; margin: 10px 0px;"></div>
					<div class="d-flex" style="border-bottom: 1px solid #EBEEEF; margin: 10px 0px;">
						<div class="informationDetailTitle">
							<% if (lang=='zh' ) { %>性別<% } else { %>Gender<% } %>
						</div>
						<div class="value informationDetailText"></div>
					</div>
					<div class="d-flex" style="border-bottom: 1px solid #EBEEEF; margin: 10px 0px;">
						<div class="informationDetailTitle">
							<% if (lang=='zh' ) { %>年齡<% } else { %>Age<% } %>
						</div>
						<div class="value informationDetailText"></div>
					</div>
					<div class="d-flex" style="border-bottom: 1px solid #EBEEEF; margin: 10px 0px;">
						<div class="informationDetailTitle">
							<% if (lang=='zh' ) { %>品種<% } else { %>Breed<% } %>
						</div>
						<div class="value informationDetailText"></div>
					</div>
					<div class="d-flex" style="border-bottom: 1px solid #EBEEEF; margin: 10px 0px;">
						<div class="informationDetailTitle">
							<% if (lang=='zh' ) { %>備註<% } else { %>Remarks<% } %>
						</div>
						<div class="remarks informationDetailText"></div>
					</div>
					<div class="d-flex" style="margin: 10px 0px;">
						<div class="informationDetailTitle">
							<% if (lang=='zh' ) { %>領養機構<% } else { %>Adoption Site<% } %>
						</div>
						<div class="value informationDetailText"></div>
					</div>
					<div class="adoption-button">
						<% if (lang=='zh' ) { %>前往領養機構<% } else { %>Go to Adoption Site<% } %> >
					</div>
					<div class="social-iconsHP">
						<img src="https://petpetclub.s3.ap-southeast-1.amazonaws.com/static-content/6822e5a8e3965735838bc5eb.png"
							width="17px" height="17px">
						<div style="margin-left: 5px; margin-right: 5px">分享：</div>
						<img src="https://petpetclub.s3.ap-southeast-1.amazonaws.com/static-content/6822e611e3965735838bc81e.png"
							width="17px" height="17px">
						<!-- Facebook Icon
						<div class="fb-share-button" data-layout="" data-size="">
							<a target="_blank" class="fb-xfbml-parse-ignore">
							<svg width="60" height="60" viewBox="0 0 60 60" fill="none" xmlns="http://www.w3.org/2000/svg">
								<path d="M60 30C60 45.152 48.768 57.6782 34.1779 59.7115C32.8132 59.9015 31.4174 60 30.0009 60C28.365 60 26.7601 59.8687 25.1951 59.6165C10.9089 57.3172 0 44.9326 0 30C0 13.4314 13.431 0 29.9991 0C46.5672 0 59.9983 13.4314 59.9983 30H60Z" fill="#1877F7"/>
								<path d="M34.1778 24.0866V30.6218H42.2623L40.9823 39.427H34.1778V59.7114C32.8131 59.9015 31.4173 59.9999 30.0008 59.9999C28.3649 59.9999 26.7601 59.8686 25.195 59.6164V39.427H17.7393V30.6218H25.195V22.6269C25.195 17.6655 29.2165 13.6421 34.1795 13.6421V13.6473C34.1933 13.6473 34.2072 13.6421 34.221 13.6421H42.2641V21.2552H37.0091C35.4458 21.2552 34.1795 22.5215 34.1795 24.0849L34.1778 24.0866Z" fill="white"/>
							</svg>
							</a>
						</div> -->
					</div>
				</div>
			</div>
		</div>


		<!-- Lower Section -->
		<div class="lower-section d-flex justify-content-center align-items-center">
			<div class="petAdvertisement">
				<img src="https://petpetclub.s3.ap-southeast-1.amazonaws.com/static-content/68241037e3965735838c54a5.png"
					width="100%" height="250px">
				<div style="position: absolute; top: 0px; left: 0px; width: 100%; height: 100%; display: flex;">
					<div style="width: 50%; height: 100%;"></div>
					<div style="width: 50%; height: 100%;" class="d-flex justify-content-center  flex-column">
						<div
							style="color: white; font-weight: 700; font-family: Arial, Helvetica, sans-serif; font-size: 48px;">
							<% if (lang=='zh' ) { %>領養代替購買<% } else { %>Adopt instead of buying<% } %>
						</div>
						<a style="color: white; background-color: #31BACE; width: 110px; height: 34px; text-decoration: none; border-radius: 10px; margin-top: 10px;"
							class="d-flex justify-content-center align-items-center"
							onmouseover="this.style.backgroundColor='#8CA2C0';"
							onmouseout="this.style.backgroundColor='#31BACE';"
							href="https://uat1.petpetclub.com.hk/Home.html">
							<% if (lang=='zh' ) { %>了解更多<% } else { %>Learn more<% } %>
						</a>
					</div>
				</div>
			</div>
			<div class="petAdvertisementHP">
				<img src="https://petpetclub.s3.ap-southeast-1.amazonaws.com/static-content/Hero+(1).png" width="100%"
					style="border-radius: 10px;" height="auto">
				<div style="width: 100%; height: 100%;background-color: #232426; padding: 20px; border-radius: 10px;"
					class="d-flex justify-content-center  flex-column">
					<div
						style="color: white; font-weight: 700; font-family: Arial, Helvetica, sans-serif; font-size: 20px;">
						<% if (lang=='zh' ) { %>領養代替購買<% } else { %>Adopt instead of buying<% } %>
					</div>
					<div class="d-flex justify-content-center align-items-center">
						<a style="color: white; border: 1px solid #31BACE; width: 100%; height: 34px; text-decoration: none; margin-top: 10px; background-color: #232426; color: #31BACE; border-radius: 5px;"
							class="d-flex justify-content-center align-items-center" href="https://petpetclub.com.hk/">
							<% if (lang=='zh' ) { %>了解更多<% } else { %>Learn more<% } %>
						</a>
					</div>
				</div>
			</div>
		</div>
	</div>

</body>

</html>