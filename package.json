{
  "name": "aws-api-tests",
  "version": "1.0.0",
  "scripts": {
    "test": "jest --runInBand",
    "test:petdetail": "node .\\node_modules\\jest\\bin\\jest.js __tests__/test-petdetailinfo.test.js --runInBand",
    "sam:build:petdetail": "sam build --template-file template.petdetailinfo.yaml",
    "sam:start:petdetail": "sam local start-api --template .aws-sam\\build\\template.yaml --env-vars env.json --warm-containers EAGER"
  },
  "jest": {
    "testTimeout": 60000,
    "setupFilesAfterEnv": [
      "<rootDir>/jest.setup.cjs"
    ]
  },
  "devDependencies": {
    "jest": "^29.7.0",
    "mongoose": "^9.4.1"
  }
}
