# Dev server happy smoke test env
# Used by:
# - __tests__/test-devserver-happy-smoke.test.js
# - postman/run-dev-happy-path.sh
# - postman/dev-happy-path*.postman_collection.json

# Base URL for test target (Dev API Gateway stage)
DEV_BASE_URL=https://udnh87tari.execute-api.ap-southeast-1.amazonaws.com/Dev

# Required for deployed API Gateway testing
# (Either DEV_API_KEY or API_GATEWAY_API_KEY can be set)
DEV_API_KEY=fCjHbweSxz9S4tNssAZ4F7FhDw69UQc25d8VsdPq

# Optional fallback key name (used only if DEV_API_KEY is empty)
API_GATEWAY_API_KEY=

# Optional: force Origin header used by tests
DEV_TEST_ORIGIN=http://localhost:3000

# Optional: enables /auth/refresh happy-path test when set
DEV_REFRESH_TOKEN=

# HS256 secret used by Postman pre-request script to mint JWTs for the
# authenticated smoke collection. Matches JWT_SECRET in env.json. Defaults
# to "PPCSecret" inside postman/run-dev-happy-path.sh when omitted.
JWT_SECRET=PPCSecret

# Stable owner fixture used by the authenticated Postman suite.
# Must be a real non-deleted Dev/UAT user and a pet owned by that user.
TEST_OWNER_USER_ID=
TEST_OWNER_EMAIL=
TEST_PET_ID=

# Optional static access tokens (if unset, Postman mints HS256 tokens using JWT_SECRET).
# Useful when you want to use real tokens from login/auth flow instead of synthetic JWTs.
USER_ACCESS_TOKEN=
ADMIN_ACCESS_TOKEN=
NGO_ACCESS_TOKEN=

# Optional owner token specifically for /v2/orderVerification/ordersInfo/{tempId}
# (if unset, defaults to USER_ACCESS_TOKEN or minted owner token).
ORDER_OWNER_ACCESS_TOKEN=

# Existing NGO fixture IDs used by the public and auth Postman suites.
# TEST_NGO_ID is also used to mint the NGO JWT claim.
TEST_NGO_ID=
PUBLIC_NGO_ID=
PUBLIC_NGO_ID_ALT=

# Optional public tag lookup fixture.
# Set this once you have a stable public tagId and lift the route into automation.
TEST_TAG_ID=

# Optional refresh-flow fixture.
# Supply a valid refreshToken cookie value if you want to automate /auth/refresh.
# Example: refreshToken=eyJ...
DEV_REFRESH_TOKEN=

# Optional NGO-role fixtures.
# These are needed only if you extend Postman coverage to the DB-role-enforced NGO endpoints.
NGO_USER_ID=
NGO_USER_EMAIL=
NGO_OWNED_PET_ID=
NGO_TRANSFER_TARGET_EMAIL=
NGO_TRANSFER_TARGET_PHONE=

# Optional pet biometric provider fixtures.
# Needed only if you automate /petBiometrics/verifyPet.
PET_BIOMETRIC_ACCESS_SECRET=
PET_BIOMETRIC_SECRET_KEY=

# Optional order-verification fixtures.
# Needed only if you automate owner/supplier/admin order-verification happy paths.
ORDER_ID=
ORDER_TEMP_ID=
ORDER_VERIFICATION_ID=
ORDER_VERIFICATION_TAG_ID=

# Optional real owner identity for ORDER_OWNER_ACCESS_TOKEN auto-mint fallback.
# If both are set (and ORDER_OWNER_ACCESS_TOKEN is empty), a short-lived owner token is minted.
ORDER_OWNER_USER_ID=
ORDER_OWNER_EMAIL=

# Optional SF Express fixtures.
# Needed only if you automate the live SF address / print flows.
SF_TYPE_ID=
SF_AREA_ID=
SF_NET_CODE=
SF_WAYBILL_NO=

# Optional external test assets.
# Useful for multipart/image-based automation if you extend the collections.
TEST_IMAGE_URL=
TEST_IMAGE_FILE=

# Optional real contact points for OTP/inbox automation.
# These alone are not enough; you also need a mailbox/SMS retrieval mechanism.
DEV_EMAIL_TEST_ADDRESS="jimmyjimmy26282@gmail.com"
DEV_SMS_TEST_PHONE="+85252668385"
